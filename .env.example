# ============================================================
#  Compagnon — environment configuration
# ============================================================
#
#  The agent uses an LLM (Anthropic Claude) for the recipe engine.
#  Copy this file to ".env" and paste your key below to run the
#  recipe engine against the real model.
#
#      cp .env.example .env
#      # then edit .env and paste your key after the = sign
#
#  Get a key at: https://console.anthropic.com
# ------------------------------------------------------------

# >>> PASTE YOUR ANTHROPIC API KEY HERE <<<
ANTHROPIC_API_KEY=insert-api-key-here

# ------------------------------------------------------------
#  OPTIONAL — leave these commented unless you need them.
#
#  Force offline / mock mode even if a key is set. In mock mode
#  the recipe engine returns a deterministic recipe and NO key is
#  required — this is how the tests and a keyless demo run.
# AGENT_MOCK=1
# ============================================================
